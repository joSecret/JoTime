---
import Layout from '../layouts/Layout.astro';
import LoginScreen from '../components/LoginScreen.astro';
import AppScreen from '../components/AppScreen.astro';
---
<Layout>
  <LoginScreen />
  <AppScreen />

  <script>
    import { createClient } from '@supabase/supabase-js';

    // ── Supabase client ────────────────────────────────────────────────────────

    const supabase = createClient(
      import.meta.env.PUBLIC_SUPABASE_URL as string,
      import.meta.env.PUBLIC_SUPABASE_ANON_KEY as string
    );

    // ── Types ──────────────────────────────────────────────────────────────────

    interface Task {
      id: string;
      name: string;
      tag: string | null;
      total_time: number;
      is_running: boolean;
      last_start_time: number | null;
    }

    interface Tag {
      id: string;
      name: string;
    }

    // ── Screen switching ───────────────────────────────────────────────────────

    const loginScreen = document.getElementById('login-screen') as HTMLDivElement;
    const appScreen   = document.getElementById('app-screen')   as HTMLDivElement;

    function showLogin(): void {
      loginScreen.classList.remove('hidden');
      appScreen.classList.add('hidden');
    }

    function showApp(): void {
      loginScreen.classList.add('hidden');
      appScreen.classList.remove('hidden');
    }

    // ── Auth ───────────────────────────────────────────────────────────────────

    const emailInput  = document.getElementById('email-input')  as HTMLInputElement;
    const sendLinkBtn = document.getElementById('send-link-btn') as HTMLButtonElement;
    const authMsg     = document.getElementById('auth-msg')      as HTMLParagraphElement;

    sendLinkBtn.addEventListener('click', async () => {
      const email = emailInput.value.trim();
      if (!email) return;
      sendLinkBtn.disabled = true;
      sendLinkBtn.textContent = 'Sending…';
      const { error } = await supabase.auth.signInWithOtp({
        email,
        options: { emailRedirectTo: window.location.origin + window.location.pathname },
      });
      sendLinkBtn.disabled = false;
      sendLinkBtn.textContent = 'Send magic link';
      authMsg.textContent = error ? error.message : 'Check your email for the magic link!';
      authMsg.style.color = error ? 'var(--danger)' : 'var(--accent-active)';
    });

    emailInput.addEventListener('keydown', (e: KeyboardEvent) => {
      if (e.key === 'Enter') sendLinkBtn.click();
    });

    document.getElementById('logout-btn')!.addEventListener('click', async () => {
      await supabase.auth.signOut();
    });

    supabase.auth.onAuthStateChange((_event, session) => {
      if (session?.user) {
        showApp();
        loadTags();
        loadTasks();
      } else {
        tasks = [];
        tags = [];
        selectedTagId = null;
        render();
        showLogin();
      }
    });

    // ── State ──────────────────────────────────────────────────────────────────

    let tasks: Task[] = [];
    let tags: Tag[] = [];
    let selectedTagId: string | null = null;
    let activeTag: string | null = null;

    async function loadTags(): Promise<void> {
      const { data } = await supabase.from('tags').select('id, name').order('name');
      if (data) { tags = data as Tag[]; renderTagDropdown(); }
    }

    async function createTag(name: string): Promise<Tag | null> {
      const { data, error } = await supabase.from('tags').insert({ name }).select('id, name').single();
      if (!error && data) { tags = [...tags, data as Tag].sort((a, b) => a.name.localeCompare(b.name)); return data as Tag; }
      return null;
    }

    async function loadTasks(): Promise<void> {
      const { data, error } = await supabase
        .from('tasks')
        .select('*')
        .order('created_at', { ascending: true });

      if (error || !data) return;

      const now = Date.now();
      const updates: Promise<unknown>[] = [];

      tasks = data.map((t: Task) => {
        if (t.is_running && t.last_start_time) {
          const recovered = { ...t, total_time: t.total_time + (now - t.last_start_time), is_running: false, last_start_time: null };
          updates.push(
            Promise.resolve(supabase.from('tasks').update({ total_time: recovered.total_time, is_running: false, last_start_time: null }).eq('id', t.id))
          );
          return recovered;
        }
        return t;
      });

      await Promise.all(updates);
      render();
    }

    // ── Timer engine ───────────────────────────────────────────────────────────

    function getDisplayTime(task: Task): number {
      if (task.is_running && task.last_start_time) {
        return task.total_time + (Date.now() - task.last_start_time);
      }
      return task.total_time;
    }

    function formatTime(ms: number): string {
      const totalSec = Math.floor(ms / 1000);
      const h = Math.floor(totalSec / 3600);
      const m = Math.floor((totalSec % 3600) / 60);
      const s = totalSec % 60;
      return [h, m, s].map(n => String(n).padStart(2, '0')).join(':');
    }

    async function startTask(id: string): Promise<void> {
      const now = Date.now();
      const running = tasks.find(t => t.is_running && t.id !== id);

      if (running) {
        const newTotal = running.total_time + (now - (running.last_start_time ?? now));
        await supabase.from('tasks').update({ total_time: newTotal, is_running: false, last_start_time: null }).eq('id', running.id);
      }
      await supabase.from('tasks').update({ is_running: true, last_start_time: now }).eq('id', id);

      tasks = tasks.map(t => {
        if (t.is_running && t.id !== id) return { ...t, total_time: t.total_time + (now - (t.last_start_time ?? now)), is_running: false, last_start_time: null };
        if (t.id === id) return { ...t, is_running: true, last_start_time: now };
        return t;
      });
      render();
    }

    async function pauseTask(id: string): Promise<void> {
      const now = Date.now();
      const task = tasks.find(t => t.id === id);
      if (!task?.is_running) return;
      const newTotal = task.total_time + (now - (task.last_start_time ?? now));
      await supabase.from('tasks').update({ total_time: newTotal, is_running: false, last_start_time: null }).eq('id', id);
      tasks = tasks.map(t => t.id === id ? { ...t, total_time: newTotal, is_running: false, last_start_time: null } : t);
      render();
    }

    async function addTask(name: string): Promise<void> {
      const trimmed = name.trim();
      if (!trimmed) return;
      const tag = tags.find(t => t.id === selectedTagId)?.name ?? null;
      const { data, error } = await supabase
        .from('tasks')
        .insert({ name: trimmed, tag, total_time: 0, is_running: false, last_start_time: null })
        .select()
        .single();
      if (!error && data) {
        tasks = [...tasks, data as Task];
        render();
      }
    }

    async function deleteTask(id: string): Promise<void> {
      await supabase.from('tasks').delete().eq('id', id);
      tasks = tasks.filter(t => t.id !== id);
      render();
    }

    async function clearAll(): Promise<void> {
      if (!tasks.length) return;
      await supabase.from('tasks').delete().in('id', tasks.map(t => t.id));
      tasks = [];
      render();
    }

    // ── Tag dropdown ───────────────────────────────────────────────────────────

    const tagSelectTrigger = document.getElementById('tag-select-trigger') as HTMLButtonElement;
    const tagSelectMenu    = document.getElementById('tag-select-menu')    as HTMLDivElement;
    const tagSelectLabel   = document.getElementById('tag-select-label')   as HTMLSpanElement;
    const tagSelectOptions = document.getElementById('tag-select-options') as HTMLDivElement;
    const tagAddBtn        = document.getElementById('tag-add-btn')        as HTMLButtonElement;

    function renderTagDropdown(): void {
      tagSelectOptions.innerHTML = '';
      const noneBtn = document.createElement('button');
      noneBtn.className = `tag-option tag-option-none${selectedTagId === null ? ' selected' : ''}`;
      noneBtn.textContent = 'No tag';
      noneBtn.addEventListener('click', () => { selectedTagId = null; updateTriggerLabel(); closeTagMenu(); });
      tagSelectOptions.appendChild(noneBtn);

      tags.forEach(tag => {
        const btn = document.createElement('button');
        btn.className = `tag-option${selectedTagId === tag.id ? ' selected' : ''}`;
        btn.textContent = tag.name;
        btn.addEventListener('click', () => { selectedTagId = tag.id; updateTriggerLabel(); closeTagMenu(); });
        tagSelectOptions.appendChild(btn);
      });
    }

    function updateTriggerLabel(): void {
      const tag = tags.find(t => t.id === selectedTagId);
      tagSelectLabel.textContent = tag ? tag.name : 'No tag';
      tagSelectTrigger.classList.toggle('has-value', !!tag);
    }

    function openTagMenu(): void { tagSelectMenu.classList.remove('hidden'); renderTagDropdown(); }
    function closeTagMenu(): void { tagSelectMenu.classList.add('hidden'); }

    tagSelectTrigger.addEventListener('click', (e) => {
      e.stopPropagation();
      tagSelectMenu.classList.contains('hidden') ? openTagMenu() : closeTagMenu();
    });

    document.addEventListener('click', (e) => {
      if (!document.getElementById('tag-select')!.contains(e.target as Node)) closeTagMenu();
    });

    // ── Tag modal ──────────────────────────────────────────────────────────────

    const tagModal       = document.getElementById('tag-modal')        as HTMLDivElement;
    const tagModalInput  = document.getElementById('tag-modal-input')  as HTMLInputElement;
    const tagModalSave   = document.getElementById('tag-modal-save')   as HTMLButtonElement;
    const tagModalCancel = document.getElementById('tag-modal-cancel') as HTMLButtonElement;

    function openTagModal(): void { closeTagMenu(); tagModal.classList.remove('hidden'); tagModalInput.value = ''; tagModalInput.focus(); }
    function closeTagModal(): void { tagModal.classList.add('hidden'); }

    tagAddBtn.addEventListener('click', openTagModal);
    tagModalCancel.addEventListener('click', closeTagModal);
    tagModal.addEventListener('click', (e) => { if (e.target === tagModal) closeTagModal(); });

    tagModalSave.addEventListener('click', async () => {
      const name = tagModalInput.value.trim();
      if (!name) return;
      tagModalSave.disabled = true;
      const tag = await createTag(name);
      tagModalSave.disabled = false;
      if (tag) { selectedTagId = tag.id; updateTriggerLabel(); renderTagDropdown(); }
      closeTagModal();
    });

    tagModalInput.addEventListener('keydown', (e: KeyboardEvent) => {
      if (e.key === 'Enter') tagModalSave.click();
      if (e.key === 'Escape') closeTagModal();
    });

    // ── Render ─────────────────────────────────────────────────────────────────

    const listEl = document.getElementById('task-list') as HTMLUListElement;
    const tagFiltersEl = document.getElementById('tag-filters') as HTMLDivElement;

    function render(): void {
      // --- Filter pills ---
      const tags = [...new Set(tasks.map(t => t.tag).filter((t): t is string => !!t))];
      if (activeTag !== null && !tags.includes(activeTag)) activeTag = null;

      if (tags.length > 0) {
        tagFiltersEl.classList.remove('hidden');
        tagFiltersEl.innerHTML = '';
        const allPill = document.createElement('button');
        allPill.className = `tag-pill${activeTag === null ? ' active' : ''}`;
        allPill.textContent = 'All';
        allPill.addEventListener('click', () => { activeTag = null; render(); });
        tagFiltersEl.appendChild(allPill);
        tags.forEach(tag => {
          const pill = document.createElement('button');
          pill.className = `tag-pill${activeTag === tag ? ' active' : ''}`;
          pill.textContent = tag;
          pill.addEventListener('click', () => { activeTag = tag; render(); });
          tagFiltersEl.appendChild(pill);
        });
      } else {
        tagFiltersEl.classList.add('hidden');
      }

      // --- Task list ---
      const visible = activeTag ? tasks.filter(t => t.tag === activeTag) : tasks;
      listEl.innerHTML = '';
      if (visible.length === 0) {
        listEl.innerHTML = '<li class="empty">No tasks yet. Add one above.</li>';
        return;
      }
      visible.forEach(task => {
        const li = document.createElement('li');
        li.className = `task-card${task.is_running ? ' running' : ''}`;
        li.dataset['id'] = task.id;

        const infoEl = document.createElement('div');
        infoEl.className = 'task-info';

        const nameEl = document.createElement('span');
        nameEl.className = 'task-name';
        nameEl.textContent = task.name;
        infoEl.appendChild(nameEl);

        if (task.tag) {
          const tagEl = document.createElement('span');
          tagEl.className = 'task-tag';
          tagEl.textContent = task.tag;
          infoEl.appendChild(tagEl);
        }

        const clock = document.createElement('span');
        clock.className = 'task-clock';
        clock.textContent = formatTime(getDisplayTime(task));

        const toggleBtn = document.createElement('button');
        toggleBtn.className = `btn btn-toggle${task.is_running ? ' active' : ''}`;
        toggleBtn.textContent = task.is_running ? 'Pause' : 'Start';
        toggleBtn.addEventListener('click', () => {
          task.is_running ? pauseTask(task.id) : startTask(task.id);
        });

        const delBtn = document.createElement('button');
        delBtn.className = 'btn btn-delete';
        delBtn.textContent = '✕';
        delBtn.addEventListener('click', () => deleteTask(task.id));

        li.append(infoEl, clock, toggleBtn, delBtn);
        listEl.appendChild(li);
      });
    }

    // ── Tick (local display only, no DB writes) ────────────────────────────────

    setInterval(() => {
      if (!tasks.some(t => t.is_running)) return;
      listEl.querySelectorAll<HTMLLIElement>('.task-card').forEach(card => {
        const id = card.dataset['id'];
        if (!id) return;
        const task = tasks.find(t => t.id === id);
        const clockEl = card.querySelector('.task-clock');
        if (task && clockEl) clockEl.textContent = formatTime(getDisplayTime(task));
      });
    }, 100);

    // ── PDF Export ─────────────────────────────────────────────────────────────

    async function exportPDF(): Promise<void> {
      const { jsPDF } = await import('jspdf');
      const doc = new jsPDF();
      const date = new Date().toLocaleDateString('en-GB', { day: '2-digit', month: 'long', year: 'numeric' });
      const totalMs = tasks.reduce((sum, t) => sum + getDisplayTime(t), 0);

      doc.setFontSize(18); doc.setTextColor(40);
      doc.text('jotime Report', 14, 20);
      doc.setFontSize(10); doc.setTextColor(100);
      doc.text(date, 14, 28);
      doc.text(`Total: ${formatTime(totalMs)}`, 14, 34);

      const hasTags = tasks.some(t => t.tag);
      doc.setFontSize(11); doc.setTextColor(40);
      doc.setFillColor(230, 230, 230);
      doc.rect(14, 42, 182, 8, 'F');
      doc.text('Task', 16, 48);
      if (hasTags) doc.text('Tag', 110, 48);
      doc.text('Duration', 155, 48);

      let y = 58;
      tasks.forEach((task, i) => {
        if (i % 2 === 0) { doc.setFillColor(248, 248, 248); doc.rect(14, y - 5, 182, 8, 'F'); }
        doc.setTextColor(40); doc.setFontSize(10);
        doc.text(task.name.slice(0, hasTags ? 45 : 60), 16, y);
        if (hasTags) doc.text(task.tag?.slice(0, 20) ?? '', 110, y);
        doc.text(formatTime(getDisplayTime(task)), 155, y);
        y += 10;
        if (y > 270) { doc.addPage(); y = 20; }
      });

      doc.save(`jotime-report-${Date.now()}.pdf`);
    }

    // ── App event listeners ────────────────────────────────────────────────────

    const taskInput = document.getElementById('task-input') as HTMLInputElement;
    const addBtn    = document.getElementById('add-btn')    as HTMLButtonElement;

    function submitAdd(): void {
      addTask(taskInput.value);
      taskInput.value = '';
      taskInput.focus();
    }

    addBtn.addEventListener('click', submitAdd);

    taskInput.addEventListener('keydown', (e: KeyboardEvent) => {
      if (e.key === 'Enter') submitAdd();
    });

    document.getElementById('clear-btn')!.addEventListener('click', clearAll);
    document.getElementById('export-btn')!.addEventListener('click', exportPDF);
  </script>
</Layout>
