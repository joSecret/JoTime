---
import '../styles/app.css';

interface Props {
  title?: string;
}
const { title = 'jotime' } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link rel="icon" href={`${import.meta.env.BASE_URL}favicon.svg`} type="image/svg+xml" />
  </head>
  <body>
    <slot />
  </body>
</html>
